      <aliases enabled='yes' />
      <column caption='Win rate %' datatype='real' name='[Calculation_3450179552446500864]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [deal_stage] = &apos;Won&apos; THEN 1 ELSE 0 END)&#10;/&#10;SUM(IF [deal_stage] IN (&apos;Won&apos;, &apos;Lost&apos;) THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Total Bookings' datatype='real' name='[Calculation_3450179552447168513]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [deal_stage] = &apos;Won&apos; THEN [close_value] ELSE 0 END)' />
      </column>
      <column caption='Weighted Pipeline' datatype='real' name='[Calculation_3450179552447533058]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#10;    IF [deal_stage] = &apos;Prospecting&apos; THEN [estimated_value] * 0.10&#10;    ELSEIF [deal_stage] = &apos;Engaging&apos; THEN [estimated_value] * 0.60&#10;    ELSE 0&#10;    END&#10;)' />
      </column>
      <column caption='Avg Sales Cycle' datatype='real' name='[Calculation_3450179552447799299]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [deal_stage] = &apos;Won&apos; THEN [sales_cycle_days] END)' />
      </column>
